# ================================================================
# DBL Digital Campaign Engine — Backend Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in the values below (replace anything in [BRACKETS])
#   3. NEVER commit .env to Git — it is in .gitignore
# ================================================================

# ----------------------------------------------------------------
# Server
# ----------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ----------------------------------------------------------------
# Database — Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Settings → Database → URI
# ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ----------------------------------------------------------------
# JWT — Used to sign admin login tokens
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------------
JWT_SECRET=[GENERATE-A-LONG-RANDOM-SECRET-MIN-32-CHARS]
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------
# CORS — Frontend URL(s) allowed to call the API
# In development this is your Vite dev server
# ----------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------------------------------------
# Logging level: error | warn | info | debug
# ----------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------
# Data Seeding — IMPORTANT
#
# SEED_DATA=false  → Server starts WITHOUT touching any data (default)
# SEED_DATA=true   → On startup, seeds default settings + creates the
#                    superadmin below (only if they don't already exist)
#
# Set to true ONLY ONCE after you push the DB schema, then set back to false.
# ----------------------------------------------------------------
SEED_DATA=false

# Only used when SEED_DATA=true
ADMIN_SEED_EMAIL=[YOUR-ADMIN-EMAIL]
ADMIN_SEED_PASSWORD=[YOUR-STRONG-PASSWORD]

# ----------------------------------------------------------------
# Optional — reCAPTCHA (leave blank to disable)
# ----------------------------------------------------------------
RECAPTCHA_SECRET_KEY=
